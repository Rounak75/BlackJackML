# ══════════════════════════════════════════════════════════════════════════════
# BlackjackML — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
venv/                   # virtual environment — recreate with: python -m venv venv
.venv/                  # alternative venv name
__pycache__/            # Python bytecode cache — auto-generated
*.pyc
*.pyo
*.pyd
*.pdb                   # Python debug files
.env                    # environment variables — never commit secrets
.env.local
.env.*.local

# ── Trained Models (large binary files — regenerate by training) ──────────────
models/                 # all trained model files live here
*.pt                    # PyTorch model checkpoint files
*.pth                   # PyTorch model state dict files
*.pkl                   # pickle files
*.onnx                  # exported ONNX models

# ── YOLO Training Data & Outputs ──────────────────────────────────────────────
yolo/dataset/           # synthetic dataset — regenerate: python yolo/generate_dataset.py
yolo/runs/              # YOLO training run logs, weights, confusion matrices
runs/                   # YOLO runs dumped in project root (ultralytics default output path)
yolo/best_card_model.pt

# ── Frontend Build Artifacts ──────────────────────────────────────────────────
# bundle.min.js is the compiled frontend — it IS committed so the app works
# without running the build step. The intermediate files are not needed.
app/static/bundle.js    # unminified intermediate bundle — not needed in repo
build-src/src/          # copied + renamed source files used during build
build-src/out/          # tsc compiled output — regenerated by build script

# ── Debug & Test Templates ─────────────────────────────────────────────────────
app/templates/diag.html # diagnostic page — exposes internal server state
app/templates/test.html # test harness — not for production


overlay_settings.json   # live scan region coordinates — different on each machine
config_local.py         # local overrides — use config.py for shared settings

# ── Session & Runtime Data ────────────────────────────────────────────────────
session_history.json    # saved session data — machine specific
*.session

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store               # macOS folder metadata
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db               # Windows thumbnail cache
ehthumbs.db
desktop.ini             # Windows folder customisation
*.Zone.Identifier       # Windows download security flag files

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/                # VS Code workspace settings
.idea/                  # JetBrains IDE settings
*.swp                   # Vim swap files
*.swo
*.bak                   # backup files
*~                      # editor temp files

# ── Logs & Temporary Files ────────────────────────────────────────────────────
*.log
*.tmp
*.temp
logs/
.pytest_cache/
htmlcov/                # pytest coverage HTML report
.coverage               # pytest coverage data file
coverage.xml

# ── Node.js (build tooling only) ──────────────────────────────────────────────
node_modules/           # if you ever run npm install locally
package-lock.json       # lock file — not needed since no package.json in root
yarn.lock
.npm

# ── Distribution / Packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ── Jupyter Notebooks (if used for analysis) ──────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ══════════════════════════════════════════════════════════════════════════════
# BlackjackML — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
# virtual environment — recreate with: python -m venv venv
venv/
# alternative venv name
.venv/
# Python bytecode cache — auto-generated
__pycache__/
*.pyc
*.pyo
*.pyd
# Python debug files
*.pdb
# environment variables — never commit secrets
.env
.env.local
.env.*.local

# ── Trained Models (large binary files — regenerate by training) ──────────────
# all trained model files live here
models/
# PyTorch model checkpoint files
*.pt
# PyTorch model state dict files
*.pth
# pickle files
*.pkl
# exported ONNX models
*.onnx

# ── YOLO Training Data & Outputs ──────────────────────────────────────────────
# synthetic dataset — regenerate: python yolo/generate_dataset.py
yolo/dataset/
# YOLO training run logs, weights, confusion matrices
yolo/runs/
# YOLO runs dumped in project root (ultralytics default output path)
runs/
yolo/best_card_model.pt

# ── Frontend Build Artifacts ──────────────────────────────────────────────────
# bundle.min.js is the compiled frontend — it IS committed so the app works
# without running the build step. The intermediate files are not needed.
# unminified intermediate bundle — not needed in repo
app/static/bundle.js
# copied + renamed source files used during build
build-src/src/
# tsc compiled output — regenerated by build script
build-src/out/

# ── Debug & Test Templates ─────────────────────────────────────────────────────
# diagnostic page — exposes internal server state
# app/templates/diag.html
# test harness — not for production
# app/templates/test.html

# live scan region coordinates — different on each machine
overlay_settings.json
# local overrides — use config.py for shared settings
config_local.py

# ── Session & Runtime Data ────────────────────────────────────────────────────
# saved session data — machine specific
session_history.json
*.session

# ── OS Files ──────────────────────────────────────────────────────────────────
# macOS folder metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows thumbnail cache
Thumbs.db
ehthumbs.db
# Windows folder customisation
desktop.ini
# Windows download security flag files
*.Zone.Identifier

# ── IDE & Editor ──────────────────────────────────────────────────────────────
# VS Code workspace settings
.vscode/
# JetBrains IDE settings
.idea/
# Vim swap files
*.swp
*.swo
# backup files
*.bak
# editor temp files
*~

# ── Logs & Temporary Files ────────────────────────────────────────────────────
*.log
*.tmp
*.temp
flake8_output.txt
test_out.txt
logs/
.pytest_cache/
# pytest coverage HTML report
htmlcov/
# pytest coverage data file
.coverage
coverage.xml

# ── Node.js (build tooling only) ──────────────────────────────────────────────
# if you ever run npm install locally
node_modules/
# lock file — not needed since no package.json in root
package-lock.json
yarn.lock
.npm

# ── Distribution / Packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ── Jupyter Notebooks (if used for analysis) ──────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── AI Agent & Knowledge Graph ────────────────────────────────────────────
# Antigravity agent config — local tooling, not project code
.agent/
# Claude Code subagent worktrees / runtime artefacts
.agents/
# Claude Code project-local settings — per-machine
.claude/
# Claude Code project instructions — local to each contributor
CLAUDE.md
# Claude Code skill packs synced to the repo — installed locally per-dev
skills/
skills-lock.json
# Brainstorming / planning docs are session-local — not tracked
docs/superpowers/
# graphify extraction cache — machine-specific, regenerated by /graphify .
# (graph.html, graph.json, GRAPH_REPORT.md are kept for collaborators)
graphify-out/cache/
graphify-out/.graphify_python
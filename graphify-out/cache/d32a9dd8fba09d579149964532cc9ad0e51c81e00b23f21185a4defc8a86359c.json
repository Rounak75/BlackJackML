                    )}\n                  </div>\n                  <span style={{ fontSize: 9, color: C.muted, flexShrink: 0 }}>\n                    {win.w > 0 ? `${win.w}\u00d7${win.h}` : ''}\n                  </span>\n                  {isActive && <span style={{ fontSize: 9, color: C.sapph }}>\u2713</span>}\n                </button>\n              );\n            };\n\n            return (\n              <>\n                {tabs.length > 0 && (\n                  <>\n                    <div style={{ padding:'4px 12px', fontSize:8, fontWeight:700,\n                      color: C.sapph, textTransform:'uppercase', letterSpacing:'0.08em',\n                      background: 'rgba(106,175,255,0.06)', borderBottom:'1px solid rgba(255,255,255,0.05)' }}>\n                      \ud83c\udf10 Browser Tabs\n                    </div>\n                    {tabs.map((w, i) => renderItem(w, i, tabs))}\n                  </>\n                )}\n                {wins.length > 0 && (\n                  <>\n                    <div style={{ padding:'4px 12px', fontSize:8, fontWeight:700,\n                      color: C.muted, textTransform:'uppercase', letterSpacing:'0.08em',\n                      background: 'rgba(255,255,255,0.03)', borderBottom:'1px solid rgba(255,255,255,0.05)',\n                      borderTop: tabs.length > 0 ? '1px solid rgba(255,255,255,0.08)' : 'none' }}>\n                      \ud83e\ude9f OS Windows\n                    </div>\n                    {wins.map((w, i) => renderItem(w, i, wins))}\n                  </>\n                )}\n                {tabs.length === 0 && wins.length > 0 && (\n                  <div style={{ padding:'6px 12px 4px', fontSize:9, color: C.muted,\n                    borderBottom:'1px solid rgba(255,255,255,0.05)' }}>\n                    \ud83d\udca1 Launch Chrome with <code style={{color:C.gold}}>--remote-debugging-port=9222</code> to see individual tabs\n                  </div>\n                )}\n              </>\n            );\n          })", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L883"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L974"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L977"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L980"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L983"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L986"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L989"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useState", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L992"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "useEffect", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L1003"}, {"caller_nid": "liveoverlaypanel_livemode", "callee": "map", "source_file": "app\\static\\components\\LiveOverlayPanel.jsx", "source_location": "L1132"}]}